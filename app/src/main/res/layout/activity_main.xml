<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0E14"
    android:padding="24dp">

    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="60dp"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ZIXINE"
            android:textColor="#FF1744"
            android:textSize="45sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.2"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="zixine elysium"
            android:textColor="#00E5FF"
            android:textSize="14sp"
            android:fontFamily="sans-serif-condensed-light"
            android:letterSpacing="0.1" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginHorizontal="10dp"
            android:orientation="vertical">
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_perf"
                android:layout_width="85dp"
                android:layout_height="85dp"
                app:cardBackgroundColor="#12161F"
                app:cardCornerRadius="43dp"
                app:strokeColor="#1E2433"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">
                <TextView
                    android:id="@+id/status_perf"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="OFF"
                    android:textColor="#44FFFFFF"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center" />
            </com.google.android.material.card.MaterialCardView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERF"
                android:textColor="#88FFFFFF"
                android:textSize="10sp"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-condensed" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginHorizontal="10dp"
            android:orientation="vertical">
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_gms"
                android:layout_width="85dp"
                android:layout_height="85dp"
                app:cardBackgroundColor="#12161F"
                app:cardCornerRadius="43dp"
                app:strokeColor="#1E2433"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">
                <TextView
                    android:id="@+id/status_gms"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="OFF"
                    android:textColor="#44FFFFFF"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center" />
            </com.google.android.material.card.MaterialCardView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GMS KILL"
                android:textColor="#88FFFFFF"
                android:textSize="10sp"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-condensed" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginHorizontal="10dp"
            android:orientation="vertical">
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_extreme"
                android:layout_width="85dp"
                android:layout_height="85dp"
                app:cardBackgroundColor="#12161F"
                app:cardCornerRadius="43dp"
                app:strokeColor="#1E2433"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">
                <TextView
                    android:id="@+id/status_extreme"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="OFF"
                    android:textColor="#44FFFFFF"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center" />
            </com.google.android.material.card.MaterialCardView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXTREME"
                android:textColor="#88FFFFFF"
                android:textSize="10sp"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-condensed" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        app:cardBackgroundColor="#12161F"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:strokeColor="#1E2433"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_trigger"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                app:cardBackgroundColor="#1E2433"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">
                <TextView
                    android:id="@+id/arrow_text"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="▲"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:textSize="18sp" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ZIXINE ELYSIUM"
                android:textColor="#00E5FF"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tutorial_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="REKOMENDASI:\nAktifkan Toggle melalui Quick Settings untuk akses lebih instan!\n\nTUTORIAL:\n1. Tarik status bar ke bawah.\n2. Klik Edit/Pensil.\n3. Cari Tiles Zixine dan seret ke atas."
                android:textColor="#66FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-light"
                android:lineSpacingExtra="4dp"
                android:visibility="gone" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</RelativeLayout>
