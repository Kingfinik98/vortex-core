<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black_bg"
    android:gravity="center"
    android:padding="20dp">

    <!-- LOCKED LAYOUT -->
    <LinearLayout
        android:id="@+id/layout_locked"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VORTEX CORE"
            android:textColor="@color/vortex_red"
            android:textSize="40sp"
            android:textStyle="bold"
            android:layout_marginBottom="30dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ENTER AUTH CODE"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/input_code"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@android:drawable/edit_text"
            android:textColor="@color/white"
            android:inputType="textPassword"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btn_unlock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UNLOCK SYSTEM"
            android:backgroundTint="@color/vortex_cyan"
            android:textColor="@color/black_bg"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- DASHBOARD -->
    <LinearLayout
        android:id="@+id/layout_dashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYSTEM MONITOR"
            android:textColor="@color/vortex_cyan"
            android:textSize="25sp"
            android:layout_marginBottom="20dp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_ram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RAM: Calculating..."
            android:textColor="@color/white"
            android:textSize="18sp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tv_zram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ZRAM: Calculating..."
            android:textColor="@color/white"
            android:textSize="18sp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tv_cpu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GOV: Checking..."
            android:textColor="@color/white"
            android:textSize="18sp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tv_battery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BAT: Checking..."
            android:textColor="@color/white"
            android:textSize="18sp"
            android:layout_marginBottom="30dp"/>

        <Button
            android:id="@+id/btn_cpu_gov"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="CHANGE GOVERNOR"
            android:backgroundTint="@color/vortex_cyan"
            android:textColor="@color/black_bg"
            android:textSize="16sp"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btn_clean_ram"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="CLEAN RAM &amp; EXIT"
            android:backgroundTint="@color/vortex_red"
            android:textColor="@color/white"
            android:textSize="16sp"/>

    </LinearLayout>
</LinearLayout>
