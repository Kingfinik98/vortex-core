<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="25dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ZIXINE"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ENGINE CORE"
            android:textColor="@color/red_zixine"
            android:textSize="12sp"
            android:layout_marginBottom="40dp" />

        <LinearLayout
            android:id="@+id/layout_locked"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <EditText
                android:id="@+id/input_code"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="ENTER PASSKEY"
                android:textColor="@color/white"
                android:textColorHint="@color/text_secondary"
                android:inputType="numberPassword"
                android:gravity="center"
                android:background="@color/gray_zixine" />

            <Button
                android:id="@+id/btn_unlock"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="20dp"
                android:text="UNLOCK"
                android:backgroundTint="@color/red_zixine"
                android:textColor="@color/white" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_verified"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView android:text="RAM" android:textColor="@color/text_secondary" android:textSize="11sp" />
            <TextView android:id="@+id/tv_ram" android:text="..." android:textColor="@color/cyan_zixine" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="15dp" />

            <TextView android:text="ZRAM" android:textColor="@color/text_secondary" android:textSize="11sp" />
            <TextView android:id="@+id/tv_zram" android:text="..." android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="15dp" />

            <TextView android:text="CPU" android:textColor="@color/text_secondary" android:textSize="11sp" />
            <TextView android:id="@+id/tv_cpu" android:text="..." android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="15dp" />

            <TextView android:text="BATTERY" android:textColor="@color/text_secondary" android:textSize="11sp" />
            <TextView android:id="@+id/tv_battery" android:text="..." android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="30dp" />

            <Button android:id="@+id/btn_cpu_gov" android:layout_width="match_parent" android:layout_height="55dp" android:text="SET GOVERNOR" android:backgroundTint="@color/cyan_zixine" android:textColor="@color/black" android:layout_marginBottom="10dp" />
            <Button android:id="@+id/btn_clean_ram" android:layout_width="match_parent" android:layout_height="55dp" android:text="CLEAN RAM" android:backgroundTint="@color/red_zixine" android:textColor="@color/white" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
